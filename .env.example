# Strava API application credentials — create yours at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Base URL the server is reachable at (used to build the OAuth redirect URI)
APP_BASE_URL=http://localhost:3001

# Strava API endpoints — only override in tests
STRAVA_API_BASE=https://www.strava.com/api/v3
STRAVA_OAUTH_BASE=https://www.strava.com/oauth

# Server
PORT=3001
# Bind address — keep 127.0.0.1 in production so only the reverse proxy reaches the app
HOST=0.0.0.0
DATABASE_PATH=./data/stravaboard.sqlite

# Where the OAuth callback redirects the browser (Vite dev server in dev, '/' in prod)
WEB_APP_URL=http://localhost:5173/

# MapTiler API key for the map panel (free at https://cloud.maptiler.com/account/keys/).
# Optional: without it the map falls back to plain OpenStreetMap (no satellite/3D).
MAPTILER_KEY=

# Signs the session cookie — set a long random value in production (openssl rand -hex 32)
COOKIE_SECRET=

# Strava athlete ids allowed to sign in, comma-separated (empty = anyone).
# A denied visitor sees their id on the sign-in page, ready to be added here.
ALLOWED_ATHLETE_IDS=
